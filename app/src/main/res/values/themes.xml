<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base dark theme -->
    <style name="Theme.HeyYa" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryContainer">@color/bg_tertiary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorSurfaceVariant">@color/bg_tertiary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <!-- Login theme -->
    <style name="Theme.HeyYa.Login">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.HeyYa.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitle</item>
    </style>

    <style name="DialogTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Card style -->
    <style name="HeyYaCard" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>
